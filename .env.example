# Astra WhatsApp AI — Environment Variables

# Server
PORT=8000
LOGLEVEL=INFO

# AI APIs
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=
ELEVENLABS_API_KEY=
AI_DEFAULT_MODEL=gpt-4o

# Green API (WhatsApp Business API)
GREEN_API_ID_INSTANCE=710722688355
GREEN_API_TOKEN_INSTANCE=db9447f903194cb08c1143440a60d70c3c1cac6a11404a5dbc
GREEN_API_URL=https://7107.api.greenapi.com
GREEN_API_PHONE=50955394345

# Database
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///astra.db

# Security
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123

# Webhook
WEBHOOK_VERIFY_TOKEN=astra-webhook-token

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
